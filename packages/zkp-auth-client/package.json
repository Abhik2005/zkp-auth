{
  "name": "@zkp-auth/client",
  "version": "0.1.2",
  "description": "Browser SDK for ZKP authentication",
  "keywords": ["zkp", "zero-knowledge", "authentication", "browser", "sdk", "typescript"],
  "author": "Vedad Kovačević",
  "repository": {
    "type": "git",
    "url": "https://github.com/Abhik2005/zkp-auth.git",
    "directory": "packages/zkp-auth-client"
  },
  "homepage": "https://github.com/Abhik2005/zkp-auth#readme",
  "bugs": {
    "url": "https://github.com/Abhik2005/zkp-auth/issues"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@noble/curves": "^1.6.0",
    "@noble/hashes": "^1.5.0",
    "@zkp-auth/core": "workspace:*"
  },
  "devDependencies": {
    "@types/jsdom": "^28.0.3",
    "jsdom": "^29.1.1",
    "tsup": "^8.0.0",
    "typescript": "^5.4.0",
    "vitest": "^1.4.0"
  },
  "files": [
    "dist"
  ],
  "license": "MIT"
}
