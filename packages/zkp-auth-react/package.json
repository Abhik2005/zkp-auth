{
  "name": "@zkp-auth/react",
  "version": "0.1.3",
  "description": "React hooks for ZKP authentication",
  "keywords": ["zkp", "zero-knowledge", "authentication", "react", "hooks", "typescript"],
  "author": "Vedad Kovačević",
  "repository": {
    "type": "git",
    "url": "https://github.com/Abhik2005/zkp-auth.git",
    "directory": "packages/zkp-auth-react"
  },
  "homepage": "https://abhik2005.github.io/zkp-auth/",
  "bugs": {
    "url": "https://github.com/Abhik2005/zkp-auth/issues"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsup",
    "test": "vitest run --passWithNoTests",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@zkp-auth/client": "workspace:*",
    "@zkp-auth/core": "workspace:*"
  },
  "peerDependencies": {
    "react": "^18.0.0",
    "react-dom": "^18.0.0"
  },
  "devDependencies": {
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "tsup": "^8.0.0",
    "typescript": "^5.4.0",
    "vitest": "^1.4.0"
  },
  "files": ["dist"],
  "license": "MIT"
}
