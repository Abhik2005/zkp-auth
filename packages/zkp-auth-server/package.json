{
  "name": "@zkp-auth/server",
  "version": "0.1.2",
  "description": "Express middleware for ZKP authentication",
  "keywords": ["zkp", "zero-knowledge", "authentication", "express", "middleware", "typescript"],
  "author": "Vedad Kovačević",
  "repository": {
    "type": "git",
    "url": "https://github.com/Abhik2005/zkp-auth.git",
    "directory": "packages/zkp-auth-server"
  },
  "homepage": "https://abhik2005.github.io/zkp-auth/",
  "bugs": {
    "url": "https://github.com/Abhik2005/zkp-auth/issues"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@zkp-auth/core": "workspace:*",
    "express": "^4.19.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.0",
    "@types/node": "^20",
    "@types/supertest": "^6.0.0",
    "supertest": "^7.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.4.0",
    "vitest": "^1.4.0"
  },
  "files": ["dist"],
  "license": "MIT"
}
